<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.techfren.live-clipper-v2</string>
  <key>ProgramArguments</key><array><string>__REPO__/.venv/bin/hermes-live-clipper</string><string>worker</string></array>
  <key>WorkingDirectory</key><string>__REPO__</string>
  <key>EnvironmentVariables</key><dict>
    <key>PATH</key><string>__REPO__/.venv/bin:__HERMES_VENV__:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>HERMES_LIVE_CLIPPER_HOME</key><string>__HOME__/.hermes/live-clipper-v2</string>
    <key>HLC_TRANSCRIBE_DEVICE</key><string>parakeet</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><dict><key>SuccessfulExit</key><false/></dict>
  <key>ThrottleInterval</key><integer>15</integer>
  <key>StandardOutPath</key><string>__HOME__/.hermes/live-clipper-v2/logs/worker.stdout.log</string>
  <key>StandardErrorPath</key><string>__HOME__/.hermes/live-clipper-v2/logs/worker.stderr.log</string>
</dict></plist>
